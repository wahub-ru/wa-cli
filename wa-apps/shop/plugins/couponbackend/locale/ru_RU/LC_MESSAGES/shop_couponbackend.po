msgid "Disable the ability to edit the \"Discount\""
msgstr "Отключить возможность редактировать «Скидку»"

msgid "This option disables the ability to change the discount value when creating and editing an order."
msgstr "Данная опция отключает возможность изменять значение скидки при создании и редактировании заказа."

msgid "Disable coupons when editing"
msgstr "Отключить купоны при редактировании"

msgid "This option disables the plugin when editing an order."
msgstr "Данная опция отключает плагин при редактировании заказа."

msgid "Application of coupons in the backend"
msgstr "Применение купонов в бекенде"

msgid "The plugin allows you to apply discount coupons in the backend of the store when creating an order"
msgstr "Плагин позволяет применять купоны на скидку в бекенде магазина, при создании заказа"

msgid "Loading promocode"
msgstr "Загрузка промокодов"

msgid "Apply"
msgstr "Применить"

msgid "Enter coupon code"
msgstr "Введите код купона"

msgid "Coupon code"
msgstr "Код купона"
